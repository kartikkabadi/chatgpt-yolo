+  const SENSITIVE_APPROVAL_RE = /\b(\x70ermission|\x61uthorize|\x61uthorization|\x67rant|\x61ccount access|\x63onnect account|\x73ign in|\x63redential|\x73ecret|\x74oken)\b/i;
   const GITHUB_CONTEXT_RE = /\b(github|repository|pull request|issue|branch|commit|workflow|workspace|permission|tool call)\b/i;
 
